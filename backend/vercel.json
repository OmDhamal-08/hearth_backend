{
  "version": 2,
  "name": "heart-disease-predictor-frontend",
  "builds": [
    {
      "src": "templates/index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "templates/$1"
    },
    {
        "src": "/",
        "dest": "templates/index.html"
    }
  ]
}
